generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// ENUMS
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

enum AccountStatus {
  ACTIVE
  SUSPENDED
  WITHDRAWN
}

enum Role {
  SUPER_ADMIN
  EXAM_ADMIN
  GRADING_ADMIN
  PROCTOR
  EXPERT
  EXAMINEE
}

enum CertType {
  AXIS
  AXIS_C
  AXIS_H
}

enum CertLevel {
  L3
  L2
  L1
}

/// L1 eligibility document review state. Gates the REAL exam; demo is unaffected.
enum EligibilityStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum ScheduleStatus {
  UPCOMING
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RegistrationStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
  REFUNDED
  EXAM_COMPLETED
}

enum PaymentMethod {
  CARD
  VBANK
  KAKAOPAY
  NAVERPAY
  TOSSPAY
  TRANSFER
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
  PARTIAL_REFUND
}

enum PenaltyStatus {
  ACTIVE
  RELEASED
}

enum ProctorEventType {
  FACE_NOT_DETECTED
  MULTIPLE_FACES
  PHONE_DETECTED
  TAB_SWITCH
  FULLSCREEN_EXIT
  COPY_PASTE
  RIGHT_CLICK
  AI_FLAG
  AI_FLAG_SUSPICIOUS
  AI_FLAG_CONFIRMED
  AUDIO_HIGH
  MANUAL_FLAG
  // в”Җв”Җв”Җ Additive (proctor v2 вҖ” gaze + page-leave detection) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // Appended to the END so MySQL ENUM ordinals are preserved on existing
  // rows. Do NOT reorder. See prisma/migrations/manual-add-proctor-event-types.sql.
  NO_FACE
  GAZE_AWAY
  EYES_CLOSED
  IDENTITY_MISMATCH
  WINDOW_BLUR
  TAB_HIDDEN
  BEFORE_UNLOAD
  KEY_BLOCKED
  EXTERNAL_DISPLAY
  POSSIBLE_MIRROR
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// USER & AUTH
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

model User {
  id                     String        @id @default(cuid())
  userId                 String        @unique @map("user_id")
  email                  String?       @unique
  passwordHash           String        @map("password_hash")
  name                   String
  phone                  String
  birthDate              String?       @map("birth_date")
  gender                 String?
  ci                     String?       @unique @db.VarChar(500)
  di                     String?       @db.VarChar(500)
  niceVerified           Boolean       @default(false) @map("nice_verified")
  accountStatus          AccountStatus @default(ACTIVE) @map("account_status")
  referenceFaceImage     Bytes?        @map("reference_face_image") @db.LongBlob
  referenceFaceUpdatedAt DateTime?     @map("reference_face_updated_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  lastLoginAt            DateTime?     @map("last_login_at")

  roles               UserRole[]
  consents            ConsentLog[]
  penalties           UserPenalty[]
  registrations       Registration[]
  examSessions        ExamSession[]
  inquiries           Inquiry[]
  demoProctoringEvents DemoProctoringEvent[]
  expertCompetencies  ExpertCompetency[]

  @@map("users")
}

model UserRole {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  role      Role
  grantedBy String?   @map("granted_by")
  grantedAt DateTime  @default(now()) @map("granted_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

/// Per-series grading scope for an EXPERT grader. The spec keeps the expert
/// review pool separated by series (AXIS / AXIS-H / AXIS-C), so an expert only
/// sees grading-queue items whose certType is in their competencies вҖ” e.g. a
/// coding expert (AXIS_C) only sees coding tasks. Admins (SUPER_ADMIN /
/// GRADING_ADMIN) are not constrained by this table.
model ExpertCompetency {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  certType  CertType @map("cert_type")
  grantedBy String?  @map("granted_by")
  grantedAt DateTime @default(now()) @map("granted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, certType])
  @@index([certType])
  @@map("expert_competencies")
}

model UserPenalty {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  sessionId     String?       @map("session_id")
  reason        String        @db.Text
  startAt       DateTime      @map("start_at")
  endAt         DateTime      @map("end_at")
  decidedBy     String?       @map("decided_by")
  status        PenaltyStatus @default(ACTIVE)
  releasedAt    DateTime?     @map("released_at")
  releaseReason String?       @map("release_reason") @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("user_penalties")
}

model ConsentLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  consentType String   @map("consent_type")
  agreed      Boolean
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent") @db.Text
  consentedAt DateTime @default(now()) @map("consented_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consent_logs")
}

model NiceSession {
  id          String    @id @default(cuid())
  requestNo   String    @unique @map("request_no")
  encData     String?   @map("enc_data") @db.Text
  authType    String    @map("auth_type")
  status      String    @default("PENDING")
  resultData  String?   @map("result_data") @db.Text
  ipAddress   String?   @map("ip_address")
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@map("nice_sessions")
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// CERTIFICATIONS
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

model Certification {
  id             String   @id @default(cuid())
  type           CertType @unique
  name           String
  nameKo         String   @map("name_ko")
  description    String   @db.Text
  targetAudience String   @map("target_audience") @db.Text
  subjects       Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  levels    CertificationLevel[]
  schedules ExamSchedule[]

  @@map("certifications")
}

model CertificationLevel {
  id               String    @id @default(cuid())
  certId           String    @map("cert_id")
  level            CertLevel
  format           String
  duration         Int
  questionCount    Int       @map("question_count")
  fee              Int
  passScore        Int       @map("pass_score")
  subjectBreakdown Json      @map("subject_breakdown")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  certification Certification @relation(fields: [certId], references: [id])

  @@unique([certId, level])
  @@map("certification_levels")
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// EXAM SCHEDULES
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

model ExamSchedule {
  id                String         @id @default(cuid())
  certType          CertType       @map("cert_type")
  level             CertLevel
  roundNumber       Int            @map("round_number")
  year              Int
  registrationStart DateTime       @map("registration_start")
  registrationEnd   DateTime       @map("registration_end")
  examDate          DateTime       @map("exam_date")
  examStartTime     String         @map("exam_start_time")
  capacity          Int
  currentCount      Int            @default(0) @map("current_count")
  status            ScheduleStatus @default(UPCOMING)
  venue             String         @default("ONLINE_CBT")
  venueDetail       String?        @map("venue_detail")
  isHolidayWarning  Boolean        @default(false) @map("is_holiday_warning")
  cancelledAt       DateTime?      @map("cancelled_at")
  cancelReason      String?        @map("cancel_reason") @db.Text
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  certification Certification  @relation(fields: [certType], references: [type])
  registrations Registration[]

  @@unique([certType, level, year, roundNumber])
  @@index([status])
  @@index([examDate])
  @@map("exam_schedules")
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// REGISTRATIONS
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

model Registration {
  id                    String             @id @default(cuid())
  userId                String             @map("user_id")
  scheduleId            String             @map("schedule_id")
  certType              CertType           @map("cert_type")
  level                 CertLevel
  status                RegistrationStatus @default(PENDING_PAYMENT)
  registrationNumber    String?            @unique @map("registration_number")
  seatNumber            Int?               @map("seat_number")
  partialExempt         Boolean            @default(false) @map("partial_exempt")
  exemptSourceSessionId String?            @map("exempt_source_session_id")
  seatHeldUntil         DateTime?          @map("seat_held_until")
  examDeadline          DateTime?          @map("exam_deadline")
  supportDocUrl         String?            @map("support_doc_url") @db.Text
  /// L1 eligibility: applicant-declared basis (L2_CERT / MANAGER_EXP / PREP_COURSE).
  eligibilityType       String?            @map("eligibility_type")
  /// L1 eligibility review state. Gates entry to the REAL exam (demo is always allowed).
  eligibilityStatus     EligibilityStatus  @default(NOT_REQUIRED) @map("eligibility_status")
  eligibilityReviewedBy String?            @map("eligibility_reviewed_by")
  eligibilityReviewedAt DateTime?          @map("eligibility_reviewed_at")
  eligibilityNote       String?            @map("eligibility_note") @db.Text
  cancelledAt           DateTime?          @map("cancelled_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id])
  schedule ExamSchedule @relation(fields: [scheduleId], references: [id])
  payments Payment[]

  @@unique([userId, scheduleId])
  @@index([userId])
  @@index([scheduleId])
  @@index([status])
  @@map("registrations")
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// PAYMENTS
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

model Payment {
  id             String         @id @default(cuid())
  registrationId String         @map("registration_id")
  orderId        String         @unique @map("order_id")
  paymentKey     String?        @unique @map("payment_key")
  amount         Int
  method         PaymentMethod?
  status         PaymentStatus  @default(PENDING)
  approvedAt     DateTime?      @map("approved_at")
  cancelledAt    DateTime?      @map("cancelled_at")
  refundAmount   Int?           @map("refund_amount")
  refundReason   String?        @map("refund_reason") @db.Text
  rawResponse    Json?          @map("raw_response")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  registration Registration @relation(fields: [registrationId], references: [id])

  @@index([registrationId])
  @@index([status])
  @@map("payments")
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// EXAM ENGINE
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

enum ExamSessionStatus {
  CREATED
  IN_PROGRESS
  SUBMITTED
  GRADED
  TERMINATED
}

enum ExamPart {
  WRITTEN
  PRACTICAL
  DELIVERABLE
  ESSAY
}

enum QuestionType {
  MCQ
  PRACTICAL_TASK
  ESSAY
  DELIVERABLE
}

model QuestionBank {
  id            String       @id @default(cuid())
  certType      CertType     @map("cert_type")
  level         CertLevel
  subjectIndex  Int          @map("subject_index")
  subjectName   String       @map("subject_name")
  type          QuestionType @default(MCQ)
  stem          String       @db.Text
  choices       Json?
  correctAnswer String?      @map("correct_answer")
  points        Int          @default(2)
  qVersion      Int          @default(1) @map("q_version")
  contentHash   String       @map("content_hash")
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now()) @map("created_at")

  // Authoring metadata imported from the question CSVs (seed-questions-csv.ts).
  no            Int?
  domainArea    String?      @map("domain_area")
  qType         String?      @map("q_type")
  itemPurpose   String?      @map("item_purpose")
  difficulty    String?
  explanation   String?      @db.Text
  sourceRef     String?      @map("source_ref")
  shuffleExempt Boolean      @default(false) @map("shuffle_exempt")
  reviewStatus  String?      @map("review_status")
  reviewComment String?      @map("review_comment")
  createdBy     String?      @map("created_by")
  createdDate   DateTime?    @map("created_date")

  // в”Җв”Җ мӢңн—ҳ н‘ңмӨҖ v2.0 question-bank infrastructure (WP10) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  /// Item lifecycle (Korean state strings вҖ” see ITEM_LIFECYCLE in
  /// question-bank-v2.ts): мҙҲм•ҲвҶ’1м°ЁкІҖмҲҳвҶ’2м°ЁкІҖмҲҳвҶ’мӮ¬м „кІҖмҰқвҶ’мҠ№мқёвҶ’л№„нҷңм„ұвҶ’нҸҗкё°.
  /// Only мҠ№мқё items are drawable as SCORED items; мӮ¬м „кІҖмҰқ items may embed as
  /// unscored pretest slots. NULL = legacy row (treated as мҠ№мқё alongside
  /// `active` so pre-v2.0 banks keep working unchanged).
  lifecycleStatus  String?   @map("lifecycle_status")
  /// v2.0 л¬ён•ӯмң нҳ• нғңк·ё (level blueprints, e.g. L3 нҳ„м—…м Ғмҡ©нҳ•/л¶„м„қВ·кІҖмҰқнҳ•вҖҰ).
  questionTypeTag  String?   @map("question_type_tag")
  /// м—…л¬ҙл§ҘлқҪ нҶөм ңм–ҙнңҳ нғңк·ё (L3 12мў… / L2 10мў… / L1 нҸүк°ҖмҳҒм—ӯ).
  businessContextTag String? @map("business_context_tag")
  /// лҰ¬мҠӨнҒ¬ нҶөм ңм–ҙнңҳ нғңк·ё.
  riskTag          String?   @map("risk_tag")
  /// м•өм»Өл¬ён•ӯ (10вҖ“15% of forms, difficulty calibration; exposure tracked).
  isAnchor         Boolean   @default(false) @map("is_anchor")
  /// Times the item was drawn into a paper (anchor/exposure management).
  exposureCount    Int       @default(0) @map("exposure_count")
  /// кё°мҲ  м „м ң мң нҳ•: м—ҶмқҢ|мөңмӢ м„ұн•ңкі„|л©”лӘЁлҰ¬В·м»Ён…ҚмҠӨнҠё|нҢҢмқјВ·лҚ°мқҙн„°мІҳлҰ¬|кі„мӮ°м •нҷ•м„ұ|кё°нғҖ.
  techAssumptionType String? @map("tech_assumption_type")
  /// мӢңнҡЁм„ұ мһ¬кІҖнҶ  мҳҲм •мқј вҖ” 12 months standard, 6 when techAssumptionType вү  м—ҶмқҢ.
  nextReviewAt     DateTime? @map("next_review_at")
  /// мӮ¬м „кІҖмҰқ нҶөкі„ (target вүҘ100 responses, м •лӢөлҘ  лӮңмқҙлҸ„ л°ҙл“ң, ліҖлі„лҸ„ вүҘ0.20,
  /// мҳӨлӢө м„ нғқлҘ  вүҘ5%): {responses, correctRate, discrimination, optionRates}.
  pretestStats     Json?     @map("pretest_stats")

  @@unique([certType, level, no])
  @@index([certType, level, subjectIndex, active])
  @@index([certType, level, lifecycleStatus])
  @@map("question_bank")
}

model TaskTemplate {
  id          String   @id @default(cuid())
  certType    CertType @map("cert_type")
  level       CertLevel
  part        ExamPart
  title       String
  scenario    String   @db.Text
  rubric      Json
  durationMin Int      @map("duration_min")
  points      Int      @default(20)
  orderIndex  Int      @default(0) @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")

  // Authoring metadata imported from the practical (мӢӨкё°) CSVs (seed-questions-csv.ts).
  setNo              Int?      @map("set_no")
  taskType           String?   @map("task_type")
  timeLimit          Int?      @map("time_limit")
  sampleData         String?   @db.Text @map("sample_data")
  requiredStructure  String?   @db.Text @map("required_structure")
  forbiddenRules     String?   @db.Text @map("forbidden_rules")
  aiToolAllowed      String?   @map("ai_tool_allowed")
  maxScore           Int?      @map("max_score")
  modelAnswer        String?   @db.Text @map("model_answer")
  riskCriteria       String?   @db.Text @map("risk_criteria")
  benchmarkExcellent String?   @db.Text @map("benchmark_excellent")
  benchmarkNormal    String?   @db.Text @map("benchmark_normal")
  benchmarkBorderline String?  @db.Text @map("benchmark_borderline")
  benchmarkFail      String?   @db.Text @map("benchmark_fail")
  aiPromptVersion    String?   @map("ai_prompt_version")
  reviewStatus       String?   @map("review_status")
  reviewComment      String?   @map("review_comment")
  version            Int       @default(1)
  createdBy          String?   @map("created_by")
  createdDate        DateTime? @map("created_date")
  isActive           Boolean   @default(true) @map("is_active")

  // в”Җв”Җ мӢңн—ҳ н‘ңмӨҖ v2.0 bank infrastructure (WP10) вҖ” mirrors QuestionBank в”Җв”Җв”Җв”Җ
  lifecycleStatus    String?   @map("lifecycle_status")
  isAnchor           Boolean   @default(false) @map("is_anchor")
  exposureCount      Int       @default(0) @map("exposure_count")
  techAssumptionType String?   @map("tech_assumption_type")
  nextReviewAt       DateTime? @map("next_review_at")
  pretestStats       Json?     @map("pretest_stats")

  @@unique([certType, level, setNo, taskType])
  @@index([certType, level, part])
  @@map("task_templates")
}

/// v2.0 final-decision state machine (к°ңл°ңмһҗ нҶөн•©лӘ…м„ём„ң v2.0). The final
/// pass/fail is ALWAYS locked by a human: AI/auto aggregation stages the
/// session as PROVISIONAL, review triggers move it to IN_REVIEW, and only an
/// admin/review panel confirms. Certificates are issued only on
/// CONFIRMED_PASS. v1.1 sessions keep `decisionStatus = null` (legacy flow).
enum DecisionStatus {
  PROVISIONAL
  IN_REVIEW
  CONFIRMED_PASS
  CONFIRMED_FAIL
  INVALIDATED
}

model ExamSession {
  id              String            @id @default(cuid())
  userId          String            @map("user_id")
  registrationId  String?           @map("registration_id")
  certType        CertType          @map("cert_type")
  level           CertLevel
  attemptNo       Int               @default(1) @map("attempt_no")
  status          ExamSessionStatus @default(CREATED)
  /// Exam standard version the session was created under ("1.1" | "2.0").
  /// Every version-dependent rule (timing, hard cuts, review bands, decision
  /// states) keys off this, so in-flight sessions keep their original rules.
  specVersion     String            @default("1.1") @map("spec_version")
  paperSeed       String?           @map("paper_seed")
  startedAt       DateTime?         @map("started_at")
  hardDeadline    DateTime?         @map("hard_deadline")
  submittedAt     DateTime?         @map("submitted_at")
  totalScore      Int?              @map("total_score")
  writtenScore    Int?              @map("written_score")
  practicalScore  Int?              @map("practical_score")
  passed          Boolean?
  failReason      String?           @map("fail_reason") @db.Text
  proctorWarnings Int               @default(0) @map("proctor_warnings")
  /// Expert grader (User.id) assigned to review this session's practical.
  assignedExpertId String?          @map("assigned_expert_id")
  /// Set by AI prescore when a spec trigger fires (low confidence / risk flag /
  /// boundary score) so graders prioritize mandatory human scrutiny.
  mandatoryReview Boolean           @default(false) @map("mandatory_review")
  /// v2.0 decision state (null for v1.1 sessions вҖ” legacy GRADED flow).
  decisionStatus  DecisionStatus?   @map("decision_status")
  confirmedAt     DateTime?         @map("confirmed_at")
  /// User.id of the admin/review-panel member who locked the decision.
  confirmedByRef  String?           @map("confirmed_by_ref")
  /// L2 v2.0 audit: embedded-AI model+version fixed for the exam round.
  embeddedAiVersion String?         @map("embedded_ai_version")
  /// L2 v2.0 audit: reference to + SHA-256 hash of the full applicantвҶ”embedded-AI
  /// prompt log (captured in EssayAnswer.aiChatLog; hashed at submit).
  promptLogRef    String?           @map("prompt_log_ref")
  promptLogHash   String?           @map("prompt_log_hash")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id])
  answers          Answer[]
  essayAnswers     EssayAnswer[]
  gradingResults   GradingResult[]
  proctoringEvents ProctoringEvent[]

  @@index([userId])
  @@index([status])
  @@index([decisionStatus])
  @@map("exam_sessions")
}

model Answer {
  id              String   @id @default(cuid())
  sessionId       String   @map("session_id")
  questionId      String   @map("question_id")
  qVersion        Int      @map("q_version")
  contentSnapshot Json     @map("content_snapshot")
  orderIndex      Int      @map("order_index")
  selectedChoice  String?  @map("selected_choice")
  flagged         Boolean  @default(false)
  version         Int      @default(0)
  isCorrect       Boolean? @map("is_correct")
  earnedPoints    Int?     @map("earned_points")
  /// v2.0 (WP10) мӮ¬м „кІҖмҰқ(л№„мұ„м җ) slot: consumes exam time, contributes 0 to
  /// every score/gate, answer recorded for item statistics. Not marked to the
  /// candidate.
  isPretest       Boolean  @default(false) @map("is_pretest")
  updatedAt       DateTime @updatedAt @map("updated_at")

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([sessionId])
  @@map("answers")
}

model EssayAnswer {
  id            String   @id @default(cuid())
  sessionId     String   @map("session_id")
  taskId        String   @map("task_id")
  part          ExamPart
  contentText   String   @map("content_text") @db.Text
  aiChatLog     Json?    @map("ai_chat_log")
  attachmentUrl String?  @map("attachment_url")
  version       Int      @default(0)
  earnedPoints  Int?     @map("earned_points")
  aiPreScore    Int?     @map("ai_pre_score")
  aiRationale   String?  @map("ai_rationale") @db.Text
  expertScore   Int?     @map("expert_score")
  expertNotes   String?  @map("expert_notes") @db.Text
  updatedAt     DateTime @updatedAt @map("updated_at")

  // AI first-pass grading detail (ClaudeEssayGraderService). aiPreScore above
  // holds the headline % so existing queue/state logic keeps working; these
  // capture the structured verdict + audit fields (brief В§5/В§8).
  aiCriterionScores Json?     @map("ai_criterion_scores")
  aiRiskFlags       Json?     @map("ai_risk_flags")
  aiBand            String?   @map("ai_band")
  aiConfidence      Float?    @map("ai_confidence")
  aiModel           String?   @map("ai_model")
  aiPromptHash      String?   @map("ai_prompt_hash")
  aiLatencyMs       Int?      @map("ai_latency_ms")
  aiScoredAt        DateTime? @map("ai_scored_at")

  // v2.0 AI grading contract (WP6): per-level gate verdict
  // ({triggered, rule, contradiction}), critical-fail pattern candidates
  // (exact enum strings from the session-aggregate schemas), and the
  // prompt-injection suspicion flag. Explicit version strings accompany the
  // existing prompt hash for baseline/audit (WP8).
  aiGate               Json?    @map("ai_gate")
  aiCriticalFails      Json?    @map("ai_critical_fails")
  aiInjectionSuspected Boolean  @default(false) @map("ai_injection_suspected")
  aiPromptVersion      String?  @map("ai_prompt_version")
  aiRubricVersion      String?  @map("ai_rubric_version")

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, taskId])
  @@index([sessionId])
  @@map("essay_answers")
}

model GradingResult {
  id            String   @id @default(cuid())
  sessionId     String   @map("session_id")
  part          ExamPart
  subjectIndex  Int      @map("subject_index")
  subjectName   String   @map("subject_name")
  earned        Int
  total         Int
  percentage    Int
  subjectFailed Boolean  @default(false) @map("subject_failed")
  createdAt     DateTime @default(now()) @map("created_at")

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("grading_results")
}

// в”Җв”Җ Hybrid grading engine (brief milestones 5вҖ“7) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

enum CalibrationStatus {
  PENDING
  PASSED
  FAILED
}

enum ScoringRound {
  FIRST // 1м°Ё
  SECOND // 2м°Ё
  ADJUST // мЎ°м •
}

/// One calibration cycle for a TaskTemplate: experts + the AI score the task's
/// benchmark exemplars; we compute expert variance, AI-vs-expert delta and
/// high-risk flag recall, then gate whether AI auto-finalize is allowed.
model CalibrationRun {
  id             String            @id @default(cuid())
  taskId         String            @map("task_id")
  status         CalibrationStatus @default(PENDING)
  expertVariance Float?            @map("expert_variance")
  aiExpertDelta  Float?            @map("ai_expert_delta")
  confidenceAvg  Float?            @map("confidence_avg")
  tolerancePassed Boolean          @default(false) @map("tolerance_passed")
  flagRecallOk   Boolean           @default(false) @map("flag_recall_ok")
  notes          String?           @db.Text
  /// v2.0 (WP8) per-criterion baseline outcomes:
  /// [{criterion, expertVariance, aiExpertDelta, passed, aiScored}] вҖ” the
  /// pass rule is |AI вҲ’ expert| вүӨ expert-expert variance per criterion;
  /// failed criteria get aiScored=false (expert direct scoring).
  criterionResults Json?           @map("criterion_results")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  scores CalibrationScore[]

  @@index([taskId])
  @@map("calibration_runs")
}

/// A single rating of one benchmark anchor, by an expert or the AI.
model CalibrationScore {
  id         String   @id @default(cuid())
  runId      String   @map("run_id")
  raterType  String   @map("rater_type") // 'expert' | 'ai'
  raterId    String?  @map("rater_id")
  anchorBand String   @map("anchor_band") // excellent | normal | borderline | fail
  total      Int
  /// v2.0 (WP8): per-criterion breakdown [{criterion, score}] so the
  /// per-criterion pass rule can be computed (not just the anchor total).
  criterionScores Json? @map("criterion_scores")
  flagged    Boolean  @default(false) // for high_risk anchors: did the rater catch the flag
  createdAt  DateTime @default(now()) @map("created_at")

  run CalibrationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("calibration_scores")
}

/// v2.0 (WP8) AI-grading baseline gate вҖ” the pre-launch protocol result for a
/// (level, taskType, promptVersion) combination. AI-assisted grading runs
/// LIVE only when a PASSED row matches; otherwise the grader operates in
/// SHADOW mode (scores stored as reference, every task routed to the expert
/// queue). Re-baseline on any prompt/model/rubric/embedded-AI version change
/// and quarterly (кё°нҡҚм„ң 9-1 / 9-4 / 11-3).
model AiBaselineGate {
  id            String    @id @default(cuid())
  level         CertLevel
  /// Practice-type label (exact enum string) or '*' for all types at the level.
  taskType      String    @map("task_type")
  promptVersion String    @map("prompt_version")
  passed        Boolean   @default(false)
  /// Criteria that FAILED the per-criterion rule вҶ’ excluded from AI scoring
  /// (grader skips them; expert UI must require them): ["мӮ°м¶ңл¬ј мҷ„м„ұлҸ„В·н’Ҳм§Ҳ", вҖҰ]
  aiExcludedCriteria Json? @map("ai_excluded_criteria")
  notes         String?   @db.Text
  validatedAt   DateTime? @map("validated_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([level, taskType, promptVersion])
  @@map("ai_baseline_gates")
}

/// Per-grader, per-round expert scoring record (brief В§5). One row per
/// (session, task, rater, round). Final sign-off carries finalAuthority.
model ExpertScoringRecord {
  id                  String       @id @default(cuid())
  sessionId           String       @map("session_id")
  taskId              String       @map("task_id")
  raterId             String       @map("rater_id")
  scoringRound        ScoringRound @map("scoring_round")
  criterionScores     Json         @map("criterion_scores")
  total               Int
  riskFlagsDetected   Json?        @map("risk_flags_detected")
  confidenceComment   String?      @map("confidence_comment") @db.Text
  adjudicationRequired Boolean     @default(false) @map("adjudication_required")
  finalDecision       String?      @map("final_decision") // 'pass' | 'fail' | null until sign-off
  finalAuthority      String?      @map("final_authority") // raterId of the chief examiner
  createdAt           DateTime     @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([sessionId, taskId])
  @@map("expert_scoring_records")
}

/// v2.0 (WP7) per-examinee session-aggregate record. `record` holds the full
/// JSON shaped by the level's AXIS_L*_мұ„м җ_м„ём…ҳм§‘кі„_JSONмҠӨнӮӨл§Ҳ_v1_0.json
/// (schema-validated at build time вҖ” see SessionAggregateService); the key
/// fields are denormalized for queue/report queries. Rebuilt (upserted) at
/// prescore-complete and at every score change / decision confirmation.
model SessionAggregate {
  id                  String    @id @default(cuid())
  sessionId           String    @unique @map("session_id")
  certType            CertType  @map("cert_type")
  level               CertLevel
  /// Lowercase decision status mirrored from the record (provisional | in_review | confirmed_pass | confirmed_fail | invalidated).
  decisionStatus      String    @map("decision_status")
  humanReviewRequired Boolean   @default(false) @map("human_review_required")
  /// Result of validating `record` against the bundled level schema.
  schemaValid         Boolean   @default(false) @map("schema_valid")
  schemaErrors        Json?     @map("schema_errors")
  record              Json
  /// Review reasons that set the flag but are NOT in the schema enum
  /// (e.g. "Part C 12м җ лҜёл§Ң") вҖ” kept out of record.review.review_reasons.
  internalReviewReasons Json?   @map("internal_review_reasons")
  aggregatedAt        DateTime  @map("aggregated_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([level, decisionStatus])
  @@index([humanReviewRequired])
  @@map("session_aggregates")
}

/// Append-only audit trail for every grading score change / finalize / publish
/// (brief В§7/В§8). Replaces the prior stdout-only logging.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String   @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  before     Json?
  after      Json?
  reason     String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorId])
  @@map("audit_logs")
}

model ProctoringEvent {
  id           String           @id @default(cuid())
  sessionId    String           @map("session_id")
  eventType    ProctorEventType @map("event_type")
  severity     String           @default("warning")
  captionKo    String?          @map("caption_ko") @db.Text
  captionEn    String?          @map("caption_en") @db.Text
  evidenceUrl  String?          @map("evidence_url") @db.Text
  videoClipUrl String?          @map("video_clip_url") @db.Text
  retainUntil  DateTime?        @map("retain_until")
  metadata     Json?
  reviewed     Boolean          @default(false)
  reviewedBy   String?          @map("reviewed_by")
  reviewedAt   DateTime?        @map("reviewed_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([eventType])
  @@map("proctoring_events")
}

// Demo runs aren't bound to an ExamSession but we still want to persist
// the captured screenshots / voice clips so the user can revisit them
// from MyPage. Stored separately from `proctoring_events` to keep real
// exam evidence cleanly isolated.
model DemoProctoringEvent {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  kind         String    @db.VarChar(64)
  severity     String    @default("warning")
  captionKo    String?   @map("caption_ko") @db.Text
  captionEn    String?   @map("caption_en") @db.Text
  evidenceUrl  String?   @map("evidence_url") @db.Text
  videoClipUrl String?   @map("video_clip_url") @db.Text
  retainUntil  DateTime? @map("retain_until")
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("demo_proctoring_events")
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// Q&A / INQUIRY SYSTEM
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

enum InquiryStatus {
  PENDING
  ANSWERED
  CLOSED
}

enum InquiryCategory {
  REGISTRATION
  PAYMENT
  EXAM
  TECHNICAL
  CERTIFICATE
  OTHER
}

model Inquiry {
  id         String          @id @default(cuid())
  userId     String          @map("user_id")
  category   InquiryCategory @default(OTHER)
  title      String
  content    String          @db.Text
  status     InquiryStatus   @default(PENDING)
  isPublic   Boolean         @default(false) @map("is_public")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies InquiryReply[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@map("inquiries")
}

model InquiryReply {
  id         String   @id @default(cuid())
  inquiryId  String   @map("inquiry_id")
  authorId   String   @map("author_id")
  content    String   @db.Text
  isAdmin    Boolean  @default(false) @map("is_admin")
  createdAt  DateTime @default(now()) @map("created_at")

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@map("inquiry_replies")
}

