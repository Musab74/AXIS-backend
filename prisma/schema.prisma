enum NoticeTagType {
  IMPORTANT
  NORMAL
}

enum NoticeStatus {
  PUBLISHED
  DRAFT
}

model Notice {
  id        String        @id @default(cuid())
  tag       String
  tagEn     String?       @map("tag_en")
  tagType   NoticeTagType @default(NORMAL) @map("tag_type")
  title     String
  titleEn   String?       @map("title_en")
  content   String        @db.Text
  contentEn String?       @map("content_en") @db.Text
  status    NoticeStatus  @default(DRAFT)
  pinned    Boolean       @default(false)
  views     Int           @default(0)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([pinned])
  @@map("notices")
}

enum FaqCategory {
  REGISTRATION
  EXAM
  PASS
  REFUND
  ENVIRONMENT
  CERTIFICATE
  OTHER
}

model Faq {
  id        String      @id @default(cuid())
  category  FaqCategory @default(OTHER)
  question  String      @db.Text
  answer    String      @db.Text
  sortOrder Int         @default(0) @map("sort_order")
  pinned    Boolean     @default(false)
  published Boolean     @default(true)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([category])
  @@index([sortOrder])
  @@map("faqs")
}
