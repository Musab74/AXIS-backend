# Copy to .env and fill in. Never commit the real .env.

DATABASE_URL="mysql://user:pass@host:3306/db"

# JWT (use openssl rand -base64 64 for production)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# App
APP_PORT=3333
APP_URL=http://localhost:3333
FRONTEND_URL=http://localhost:5173

# AI Proctoring — without these, AI cheating detection is OFFLINE.
#   Tier-1: Google Gemini Flash-Lite screens every webcam frame (cheap).
#   Tier-2: Anthropic Claude Sonnet verifies + writes the cheating event.
# Canonical names below; legacy GEMINI_API_KEY / GOOGLE_API_KEY / CLAUDE_API_KEY
# are also accepted as fallbacks so a misnamed key still wires up the AI.
# When ANTHROPIC_API_KEY is missing, the backend falls back to a Gemini-only
# verdict at higher confidence bars (phone-class >=0.6, others >=0.7) so
# detection still works at reduced precision. See ai-proctor.service.ts.
GOOGLE_GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Naver Cloud Object Storage — evidence frames bucket. When unset, evidence
# is written to ./uploads and served via HMAC-signed local URLs (dev fallback).
NCP_ACCESS_KEY=
NCP_SECRET_KEY=
NCP_REGION=kr-standard
NCP_ENDPOINT=https://kr.object.ncloudstorage.com
NCP_BUCKET_SNAPSHOTS=axis-snapshots

# PortOne — NHN KCP virtual account (apply flow /apply Step 4)
# PORTONE_MODULE_VERSION selects which SDK/API the backend uses.
#   v2 (default, ACTIVE): @portone/server-sdk + browser-sdk/v2. Requires
#     PORTONE_STORE_ID, PORTONE_CHANNEL_KEY, PORTONE_V2_API_SECRET and
#     PORTONE_WEBHOOK_SECRET (whsec_..., signed-webhook verification).
#   v1: legacy IAMPORT REST + iamport.js — fully implemented fallback only;
#     do not select for new environments. Uses PORTONE_V1_* vars below.
# PORTONE_CHANNEL_KEY is reused across versions (one active channel per env).
PORTONE_MODULE_VERSION=v2
PORTONE_STORE_ID=
PORTONE_CHANNEL_KEY=
PORTONE_V2_API_SECRET=
PORTONE_WEBHOOK_SECRET=
PORTONE_WEBHOOK_SECRET_ARN=
PORTONE_V1_IMP_CODE=
PORTONE_V1_IMP_KEY=
PORTONE_V1_IMP_SECRET=
PORTONE_V1_PG_PROVIDER=kcp
# Prefer exact pg from PortOne console (e.g. kcp, kcp.IP7MM). Overrides SITE_CODE when set.
# PORTONE_V1_PG=kcp
# Or: PORTONE_V1_KCP_SITE_CODE= → builds kcp.{code}
PORTONE_V1_KCP_SITE_CODE=

# Optional: comma-separated source-IP allowlist for /webhooks/portone.
# iamport (V1) webhook IPs: 52.78.100.19,52.78.48.223,52.78.5.241
# Requires the edge proxy to forward X-Forwarded-For. Empty = disabled
# (safe: webhook state changes are gated on PG API re-fetch regardless).
PORTONE_WEBHOOK_ALLOWED_IPS=

# NICE CheckPlus / I-PIN (본인인증) — native binaries bundled under lib/nice/
# Register `${APP_URL}/auth/nice/checkplus-return` with NICE for your sitecode.
# NICE_CHECKPLUS_SITECODE=
# NICE_CHECKPLUS_SITEPASSWD=
# NICE_IPIN_SITECODE=
# NICE_IPIN_SITEPASSWD=
# NICE_CHECKPLUS_MODULE_PATH=   # optional; defaults to lib/nice/CheckPlusSafe/64bit/CPClient_64bit
# NICE_IPIN_MODULE_PATH=        # optional; defaults to lib/nice/NiceIPIN/64bit/IPIN2Client
# NICE_DEV_MODE=false

# (default 121.168.121.86). Your reverse proxy must forward X-Forwarded-For.
# ADMIN_FOOTER_ALLOWED_IP=121.168.121.86
# ADMIN_PORTAL_URL=https://admin.example.com

# Dev/staging only — password for the internal payment-QA account (test000)
# created by `npm run db:seed:payment-checker`. No default; the seed refuses to
# run without it, and refuses to run when NODE_ENV=production. Never commit a
# real value. Optionally override the login id with PAYMENT_CHECKER_USER_ID.
# PAYMENT_CHECKER_PASSWORD=
# PAYMENT_CHECKER_USER_ID=test000

# ─── Transactional email (AWS SES v2) ────────────────────────────────────────
# Sends the payment receipt, the payment-failure notice, and the seat-hold /
# exam-deadline / certificate-expiry warnings. Credentials come from the AWS_*
# block above (region ap-northeast-2 — SES is available there).
#
# MAIL_ENABLED=false (the default) makes MailerService RENDER and LOG each mail
# instead of sending it, so dev/staging never mail real candidates even when
# running against a prod dump. Turn it on only where you intend to send.
#
# Before MAIL_ENABLED=true works in production:
#   1. Verify the axisexam.com domain in SES, then publish the DKIM CNAMEs and an
#      SPF TXT record. Naver/Daum hard-filter unauthenticated senders — without
#      this, exam-deadline warnings land in spam and candidates miss their exam.
#   2. Request SES production access. A new account is sandboxed and can only
#      send to pre-verified addresses; approval takes ~24h.
#   3. MAIL_FROM must be on the verified domain or SES rejects the send.
# MAIL_ENABLED=false
# MAIL_FROM=no-reply@axisexam.com
# MAIL_FROM_NAME=AXIS
# MAIL_REPLY_TO=
# MAIL_EXAM_DEADLINE_REMINDER_DAYS=3    # D-N warning before examDeadline
# MAIL_CERT_EXPIRY_REMINDER_DAYS=30     # D-N warning before a certificate lapses
