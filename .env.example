# Copy to .env and fill in. Never commit the real .env.

DATABASE_URL="mysql://user:pass@host:3306/db"

# JWT (use openssl rand -base64 64 for production)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# App
APP_PORT=3333
APP_URL=http://localhost:3333
FRONTEND_URL=http://localhost:5173

# Toss Payments — TEST keys for dev/staging, LIVE keys only in prod vault
TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxx
TOSS_WEBHOOK_SECRET=
TOSS_API_BASE_URL=https://api.tosspayments.com
